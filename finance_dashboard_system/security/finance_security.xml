<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==== RECORD RULES ==== -->
    <!-- Viewer: only read own company records -->
    <record id="rule_finance_viewer_read" model="ir.rule">
        <field name="name">Finance Viewer: Read own company</field>
        <field name="model_id" ref="model_finance_record"/>
        <field name="groups" eval="[(4, ref('group_viewer'))]"/>
        <field name="domain_force">[('create_uid.company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Analyst: read all records of own company -->
    <record id="rule_finance_analyst_read" model="ir.rule">
        <field name="name">Finance Analyst: Read own company</field>
        <field name="model_id" ref="model_finance_record"/>
        <field name="groups" eval="[(4, ref('group_analyst'))]"/>
        <field name="domain_force">[('create_uid.company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Admin: full access -->
    <record id="rule_finance_admin_full" model="ir.rule">
        <field name="name">Finance Admin: Full access</field>
        <field name="model_id" ref="model_finance_record"/>
        <field name="groups" eval="[(4, ref('finance_dashboard_system.group_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>