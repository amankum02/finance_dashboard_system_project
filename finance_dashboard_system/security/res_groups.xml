<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="finance_security_category" model="ir.module.category">
            <field name="name">Finance</field>
            <field name="description">Finance Roles</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="category_id" ref="finance_security_category"/>
        </record>
        
        <record id="group_analyst" model="res.groups">
            <field name="name">Analyst</field>
            <field name="category_id" ref="finance_security_category"/>
            <field name="implied_ids" eval="[(4, ref('group_viewer'))]"/>
        </record>

        <record id="group_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="finance_security_category"/>
            <field name="implied_ids" eval="[(4, ref('group_analyst'))]"/>
        </record>
    </data>
</odoo>